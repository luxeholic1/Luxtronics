# ── Firebase Auth ────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── Admin access (comma-separated emails) ────────────────────────────────────
VITE_ADMIN_EMAILS=admin@luxtronics.in

# ── Hostinger FTP Deployment (Multi-Domain Support) ──────────────────────────
FTP_HOST=ftp.luxtronics.in
FTP_USER=your_ftp_username
FTP_PASS=your_ftp_password
FTP_REMOTE_DIR=/public_html

# ── WooCommerce API ───────────────────────────────────────────────────────────
VITE_WOOCOMMERCE_URL=https://your-store.com
VITE_WOOCOMMERCE_KEY=ck_your_consumer_key
VITE_WOOCOMMERCE_SECRET=cs_your_consumer_secret

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_DB_NAME=luxtronics

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=https://luxtronics.in
SYNC_TOKEN=your_sync_token_here

# ── Note: Products will use same Firebase project as auth ────────────────────
# No separate Firebase project needed for products
# Firestore collections: products, categories, sync_status
