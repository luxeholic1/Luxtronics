# ── Clerk Auth ───────────────────────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# ── Hostinger FTP Deployment (Multi-Domain Support) ────────────────────────
# Find these in: Hostinger hPanel → Hosting → FTP Accounts
# For multi-domain, create separate hosting accounts or use addon domains

# US Domain (luxtronics.com)
FTP_HOST_US=ftp.luxtronics.com
FTP_USER_US=u123456789
FTP_PASS_US=your_us_ftp_password_here
FTP_REMOTE_DIR_US=/public_html

# Australian Domain (luxtronics.com.au)
FTP_HOST_AU=ftp.luxtronics.com.au
FTP_USER_AU=u987654321
FTP_PASS_AU=your_au_ftp_password_here
FTP_REMOTE_DIR_AU=/public_html

# New Zealand Domain (luxtronics.co.nz)
FTP_HOST_NZ=ftp.luxtronics.co.nz
FTP_USER_NZ=u112233445
FTP_PASS_NZ=your_nz_ftp_password_here
FTP_REMOTE_DIR_NZ=/public_html

# Indian Domain (luxtronics.in)
FTP_HOST_IN=ftp.luxtronics.in
FTP_USER_IN=u556677889
FTP_PASS_IN=your_in_ftp_password_here
FTP_REMOTE_DIR_IN=/public_html

# Indian-Australia Domain (luxtronics.in.au)
FTP_HOST_IN_AU=ftp.luxtronics.in.au
FTP_USER_IN_AU=u998877665
FTP_PASS_IN_AU=your_in_au_ftp_password_here
FTP_REMOTE_DIR_IN_AU=/public_html

# Indian-New Zealand Domain (luxtronics.in.nz)
FTP_HOST_IN_NZ=ftp.luxtronics.in.nz
FTP_USER_IN_NZ=u443322110
FTP_PASS_IN_NZ=your_in_nz_ftp_password_here
FTP_REMOTE_DIR_IN_NZ=/public_html

# ── Single Account Alternative (if using addon domains) ─────────────────────
# If using one Hostinger account with addon domains, use subdirectories:
# FTP_HOST=ftp.yourdomain.com
# FTP_USER=u123456789
# FTP_PASS=your_ftp_password_here
# FTP_REMOTE_DIR_US=/public_html
# FTP_REMOTE_DIR_AU=/public_html/au
# FTP_REMOTE_DIR_NZ=/public_html/nz
# FTP_REMOTE_DIR_IN=/public_html/in
