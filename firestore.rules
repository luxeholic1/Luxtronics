rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Products (public read, no write from client) ──────────────────────
    match /products/{productId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Categories (public read, no write from client) ────────────────────
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Sync status (public read, no write from client) ───────────────────
    match /sync_status/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Users (only authenticated user can read/write their own data) ─────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
